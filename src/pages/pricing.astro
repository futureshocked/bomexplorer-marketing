---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PricingCard from '../components/PricingCard.astro';
---

<MarketingLayout title="Pricing - BOMexplorer" currentPage="pricing">
	<section class="py-20 px-4 sm:px-6 lg:px-8">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-16">
				<h1 class="text-5xl font-bold text-[var(--color-text)] mb-6 font-mono">
					Pricing
				</h1>
				<p class="text-xl text-[var(--color-text-muted)] max-w-3xl mx-auto mb-12">
					Start free, scale as you grow. No hidden fees, no surprise charges.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
				<PricingCard
					title="Free"
					price="Free"
					description="Perfect for small projects and getting started"
					features={[
						"Up to 3 projects",
						"Up to 50 parts per project",
						"3 providers: OEMSecrets, DigiKey, Mouser",
						"50 AI Assist lines/month",
						"5 AI Explainer invocations/month",
						"CSV export",
						"Natural language BOM filtering",
						"Part alternatives + substitution history",
						"Manual search",
						"Lock/unlock BOM lines",
						"DNP marking",
						"Price monitoring (nightly alerts)",
						"Project cloning"
					]}
				/>
				<PricingCard
					title="Pro"
					price="$10/month"
					description="For serious hardware development"
					features={[
						"Unlimited projects",
						"Unlimited parts per project",
						"5 providers (+ Nexar premium, FindChips premium)",
						"500 AI Assist lines/month",
						"20 AI Explainer invocations/month",
						"XLSX export (Excel format)",
						"Natural language BOM filtering",
						"Part alternatives + substitution history",
						"Manual search",
						"Lock/unlock BOM lines",
						"DNP marking",
						"Price monitoring (nightly alerts)",
						"Project cloning",
						"60-day Pro trial available"
					]}
					popular={true}
				/>
				<PricingCard
					title="Token Packs"
					price="From $5"
					description="Add-on for when AI quotas are exhausted"
					features={[
						"Available on any plan",
						"One-time purchase via Paddle",
						"Tokens do not expire monthly",
						"Starter pack: 100 tokens, $5 USD",
						"180-day token expiry",
						"Use when AI Assist quota runs out",
						"Use when AI Explainer quota runs out",
						"Multiple pack options available"
					]}
				/>
			</div>

			<!-- Paddle Checkout Screenshot Placeholder -->
			<div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-8 mb-16 shadow-[var(--shadow-card)]">
				<div class="text-center mb-8">
					<h2 class="text-2xl font-bold text-[var(--color-text)] mb-6 font-mono">
						Secure checkout via Paddle
					</h2>
					<p class="text-[var(--color-text-muted)] mb-6">
						All Pro subscriptions are processed securely through Paddle — our payment partner. One-click checkout with support for cards, Apple Pay, and more.
					</p>
					<!-- Screenshot Placeholder -->
					<div class="bg-[var(--color-bg)] rounded border-2 border-dashed border-[var(--color-border)] max-w-2xl mx-auto min-h-[200px] flex flex-col items-center justify-center p-8 text-center">
						<svg class="w-12 h-12 text-[var(--color-text-muted)] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
						</svg>
						<span class="text-[var(--color-text-muted)] text-sm font-mono">SCREENSHOT PLACEHOLDER</span>
						<span class="text-[var(--color-text-muted)] text-xs mt-2">Show Paddle checkout overlay with subscription selection</span>
					</div>
				</div>
			</div>

			<!-- Subscription Management -->
			<div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-8 mb-16 shadow-[var(--shadow-card)]">
				<h2 class="text-2xl font-bold text-[var(--color-text)] mb-8 text-center font-mono">
					Subscription management
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="text-center">
						<div class="w-12 h-12 bg-[var(--color-secondary-dim)] rounded-full flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">Upgrade anytime</h3>
						<p class="text-[var(--color-text-muted)] text-sm">Move from Free to Pro instantly with Paddle checkout. No downtime, no data loss.</p>
					</div>
					<div class="text-center">
						<div class="w-12 h-12 bg-[var(--color-secondary-dim)] rounded-full flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">Cancel at period end</h3>
						<p class="text-[var(--color-text-muted)] text-sm">Cancel anytime from preferences. Access continues until billing period ends.</p>
					</div>
					<div class="text-center">
						<div class="w-12 h-12 bg-[var(--color-secondary-dim)] rounded-full flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">Reactivate anytime</h3>
						<p class="text-[var(--color-text-muted)] text-sm">Cancelled but want to come back? Reactivate with one click. Your data is preserved.</p>
					</div>
				</div>
			</div>

			<!-- FAQ Section -->
			<div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-8 shadow-[var(--shadow-card)]">
				<h2 class="text-2xl font-bold text-[var(--color-text)] mb-8 text-center font-mono">
					Frequently asked questions
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<div>
						<h3 class="text-lg font-semibold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">Is the free tier really free?</h3>
						<p class="text-[var(--color-text-muted)] mb-6">
							Yes, always. No credit card required. Free tier includes 3 projects, 50 parts per project, 3 providers (OEMSecrets, DigiKey, Mouser), 50 AI Assist lines/month, and 5 AI Explainer invocations/month.
						</p>

						<h3 class="text-lg font-semibold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">Which providers are supported?</h3>
						<p class="text-[var(--color-text-muted)] mb-6">
							Free tier: OEMSecrets (free aggregator), DigiKey, Mouser. Pro tier adds Nexar (premium — lifecycle status, tech specs) and FindChips (premium aggregator). Free users see premium providers skipped in results with "premium_plan_required" reason.
						</p>

						<h3 class="text-lg font-semibold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">Do you offer discounts?</h3>
						<p class="text-[var(--color-text-muted)]">
							Contact us for academic and open-source project discounts. We support educators and community builders.
						</p>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">What is AI Assist vs AI Explainer?</h3>
						<p class="text-[var(--color-text-muted)] mb-6">
							AI Assist: Natural language BOM filtering and part classification (50 lines/mo free, 500 Pro). AI Explainer: AI-powered explanations for component details (5/mo free, 20 Pro).
						</p>

						<h3 class="text-lg font-semibold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">Can I cancel anytime?</h3>
						<p class="text-[var(--color-text-muted)] mb-6">
							Yes. No lock-in contracts. Cancel from preferences and keep access until billing period ends. Your data is preserved.
						</p>

						<h3 class="text-lg font-semibold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">What are Token Packs?</h3>
						<p class="text-[var(--color-text-muted)]">
							One-time token purchases via Paddle for when AI quotas are exhausted. Starter pack: 100 tokens at $5 USD with 180-day expiry. Tokens do not expire monthly.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</MarketingLayout>