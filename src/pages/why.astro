								<span class="bg-[var(--color-secondary)]/10 text-[var(--color-secondary)] text-xs font-semibold px-2 py-1 rounded">Platform</span>
							</div>
							<h2 class="text-3xl font-bold text-[var(--color-text)] mb-6 font-mono">Full admin control</h2>
							<p class="text-[var(--color-text-muted)] leading-relaxed mb-6">
								BOMexplorer gives administrators complete visibility and control over provider health, user management, AI budgets, and platform settings. Everything needed to run a BOM management platform at scale.
							</p>
							<div class="space-y-3">
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Provider health dashboard</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Real-time provider status, usage bars, ping tests with latency, auto-refresh.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">User management</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Searchable user list, per-project BOM counts, disable/enable users.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">AI usage tracking</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Per-feature token usage with cost calculation and budget controls.</p>
									</div>
								</div>
							</div>
						</div>
						<div class="order-1 lg:order-1">
							<!-- Screenshot Placeholder -->
							<div class="bg-[var(--color-bg)] rounded border-2 border-dashed border-[var(--color-border)] min-h-[280px] flex flex-col items-center justify-center p-8 text-center">
								<svg class="w-12 h-12 text-[var(--color-text-muted)] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
								</svg>
