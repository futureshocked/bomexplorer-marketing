---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Why BOMexplorer - 6 Reasons to Switch" currentPage="why">
	<!-- Hero -->
	<section class="py-20 px-4 sm:px-6 lg:px-8">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-16">
				<span class="text-xs font-mono text-[var(--color-secondary)] uppercase tracking-widest border border-[var(--color-secondary)]/30 rounded-full px-3 py-1">[ WHY BOMEXPLORER ]</span>
				<h1 class="text-5xl font-bold text-[var(--color-text)] mt-6 mb-6 font-mono">
					6 reasons hardware engineers choose us
				</h1>
				<p class="text-xl text-[var(--color-text-muted)] max-w-3xl mx-auto leading-relaxed">
					BOMexplorer isn't just another BOM tool. It's the only platform that combines multi-provider aggregation, AI-powered matching, and supply chain monitoring in one workflow.
				</p>
			</div>

			<!-- Differentiator 1: Multi-Provider Aggregation -->
			<div class="mb-24">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div>
						<div class="mb-4 flex items-center gap-3">
							<span class="text-[var(--color-secondary)] text-sm font-mono font-bold tracking-widest">[ 01 ]</span>
							<span class="bg-[var(--color-secondary)]/10 text-[var(--color-secondary)] text-xs font-semibold px-2 py-1 rounded">Unique Capability</span>
						</div>
						<h2 class="text-3xl font-bold text-[var(--color-text)] mb-6 font-mono">6 providers. One search.</h2>
						<p class="text-[var(--color-text-muted)] leading-relaxed mb-6">
							While other tools query a single distributor, BOMexplorer searches Nexar, OEMSecrets, DigiKey, Mouser, FindChips, and NextPCB simultaneously — or uses a smart fallback chain if one returns no results.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<span class="text-[var(--color-secondary)] mt-1">✓</span>
								<div>
									<h4 class="text-[var(--color-text)] font-semibold text-sm">Automatic fallback</h4>
									<p class="text-[var(--color-text-muted)] text-sm">If one provider has no results, the next is tried automatically.</p>
								</div>
							</div>
							<div class="flex items-start gap-3">
								<span class="text-[var(--color-secondary)] mt-1">✓</span>
								<div>
									<h4 class="text-[var(--color-text)] font-semibold text-sm">Configurable provider order</h4>
									<p class="text-[var(--color-text-muted)] text-sm">Admins can set the provider sequence based on pricing preference.</p>
								</div>
							</div>
							<div class="flex items-start gap-3">
								<span class="text-[var(--color-secondary)] mt-1">✓</span>
								<div>
									<h4 class="text-[var(--color-text)] font-semibold text-sm">Source badge per row</h4>
									<p class="text-[var(--color-text-muted)] text-sm">Every BOM line shows exactly which provider supplied the match.</p>
								</div>
							</div>
						</div>
					</div>
					<div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6 shadow-[var(--shadow-card)]">
						<!-- Screenshot Placeholder -->
						<div class="bg-[var(--color-bg)] rounded border-2 border-dashed border-[var(--color-border)] min-h-[280px] flex flex-col items-center justify-center p-8 text-center">
							<svg class="w-12 h-12 text-[var(--color-text-muted)] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
							<span class="text-[var(--color-text-muted)] text-sm font-mono">SCREENSHOT PLACEHOLDER</span>
							<span class="text-[var(--color-text-muted)] text-xs mt-2">Show BOM table with provider source badges (Mouser, DigiKey, etc.)</span>
						</div>
					</div>
				</div>
			</div>

			<!-- Differentiator 2: AI-Powered Matching -->
			<div class="mb-24 bg-[var(--color-surface)] py-16 px-8 rounded-lg shadow-[var(--shadow-card)]">
				<div class="max-w-7xl mx-auto">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
						<div class="order-2 lg:order-2">
							<div class="mb-4 flex items-center gap-3">
								<span class="text-[var(--color-secondary)] text-sm font-mono font-bold tracking-widest">[ 02 ]</span>
								<span class="bg-[var(--color-secondary)]/10 text-[var(--color-secondary)] text-xs font-semibold px-2 py-1 rounded">AI-Powered</span>
							</div>
							<h2 class="text-3xl font-bold text-[var(--color-text)] mb-6 font-mono">AI that understands KiCad quirks</h2>
							<p class="text-[var(--color-text-muted)] leading-relaxed mb-6">
								BOMexplorer uses Claude AI to classify components that traditional matching can't handle — crystal symbols, fiducials, mounting holes, and copper-only net ties. It generates targeted queries specific to each provider's API.
							</p>
							<div class="space-y-3">
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Hierarchical matching</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Exact MPN → hyphen-stripped MPN → distributor part number → keyword search.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Smart skip list</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Auto-skips unmatchable values (TestPoint, LED, Fiducial) unless an explicit MPN is provided.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Confidence badges</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Visual indicators: exact MPN, parametric, keyword, AI-suggested, unmatched.</p>
									</div>
								</div>
							</div>
						</div>
						<div class="order-1 lg:order-1">
							<!-- Screenshot Placeholder -->
							<div class="bg-[var(--color-bg)] rounded border-2 border-dashed border-[var(--color-border)] min-h-[320px] flex flex-col items-center justify-center p-8 text-center">
								<svg class="w-12 h-12 text-[var(--color-text-muted)] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
								</svg>
								<span class="text-[var(--color-text-muted)] text-sm font-mono">SCREENSHOT PLACEHOLDER</span>
								<span class="text-[var(--color-text-muted)] text-xs mt-2">Show confidence badges and AI classification indicators on BOM rows</span>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Differentiator 3: Supply Chain Monitoring -->
			<div class="mb-24">
				<div class="max-w-7xl mx-auto">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
						<div>
							<div class="mb-4 flex items-center gap-3">
								<span class="text-[var(--color-secondary)] text-sm font-mono font-bold tracking-widest">[ 03 ]</span>
								<span class="bg-[var(--color-secondary)]/10 text-[var(--color-secondary)] text-xs font-semibold px-2 py-1 rounded">Continuous Monitoring</span>
							</div>
							<h2 class="text-3xl font-bold text-[var(--color-text)] mb-6 font-mono">Overnight supply chain alerts</h2>
							<p class="text-[var(--color-text-muted)] leading-relaxed mb-6">
								Set your BOM and forget it. BOMexplorer runs overnight re-queries on all active BOM lines, detecting price changes, stock drops, end-of-life notices, and lead time increases before they derail your production run.
							</p>
							<div class="space-y-3">
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Flag detection</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Out-of-stock, low-stock, price spikes, EOL, lead-time increases.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Alert lifecycle</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Open → Watching → Ignored → Resolved with snooze support.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Morning email digest</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Daily summary email of new flags so you start the day informed.</p>
									</div>
								</div>
							</div>
						</div>
						<div>
							<!-- Screenshot Placeholder -->
							<div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6 shadow-[var(--shadow-card)]">
								<div class="bg-[var(--color-bg)] rounded border-2 border-dashed border-[var(--color-border)] min-h-[280px] flex flex-col items-center justify-center p-8 text-center">
									<svg class="w-12 h-12 text-[var(--color-text-muted)] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
									</svg>
									<span class="text-[var(--color-text-muted)] text-sm font-mono">SCREENSHOT PLACEHOLDER</span>
									<span class="text-[var(--color-text-muted)] text-xs mt-2">Show alert dashboard with OOS, price spike, and EOL flags</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Differentiator 4: Natural Language Query -->
			<div class="mb-24 bg-[var(--color-surface)] py-16 px-8 rounded-lg shadow-[var(--shadow-card)]">
				<div class="max-w-7xl mx-auto">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
						<div class="order-2 lg:order-2">
							<div class="mb-4 flex items-center gap-3">
								<span class="text-[var(--color-secondary)] text-sm font-mono font-bold tracking-widest">[ 04 ]</span>
								<span class="bg-[var(--color-secondary)]/10 text-[var(--color-secondary)] text-xs font-semibold px-2 py-1 rounded">AI Assist</span>
							</div>
							<h2 class="text-3xl font-bold text-[var(--color-text)] mb-6 font-mono">Talk to your BOM in plain English</h2>
							<p class="text-[var(--color-text-muted)] leading-relaxed mb-6">
								Need to find all capacitors under $0.10? Or surface-mount resistors with low stock? Just type it. BOMexplorer's AI Assist understands natural language queries and highlights matching rows in real-time — a rare UX feature in BOM management tools.
							</p>
							<div class="space-y-3">
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Powered by Claude Haiku</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Fast, cost-effective AI for responsive BOM filtering.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Debounced input</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Real-time highlighting as you type without lag.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Amber row highlighting</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Matching rows are visually highlighted for instant recognition.</p>
									</div>
								</div>
							</div>
						</div>
						<div class="order-1 lg:order-1">
							<!-- Screenshot Placeholder -->
							<div class="bg-[var(--color-bg)] rounded border-2 border-dashed border-[var(--color-border)] min-h-[280px] flex flex-col items-center justify-center p-8 text-center">
								<svg class="w-12 h-12 text-[var(--color-text-muted)] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
								</svg>
								<span class="text-[var(--color-text-muted)] text-sm font-mono">SCREENSHOT PLACEHOLDER</span>
								<span class="text-[var(--color-text-muted)] text-xs mt-2">Show natural language query input with highlighted matching rows</span>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Differentiator 5: Substitution Management -->
			<div class="mb-24">
				<div class="max-w-7xl mx-auto">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
						<div>
							<div class="mb-4 flex items-center gap-3">
								<span class="text-[var(--color-secondary)] text-sm font-mono font-bold tracking-widest">[ 05 ]</span>
								<span class="bg-[var(--color-secondary)]/10 text-[var(--color-secondary)] text-xs font-semibold px-2 py-1 rounded">Workflow</span>
							</div>
							<h2 class="text-3xl font-bold text-[var(--color-text)] mb-6 font-mono">One-click swaps with full history</h2>
							<p class="text-[var(--color-text-muted)] leading-relaxed mb-6">
								When a part goes out of stock or you find a better price, BOMexplorer makes substitution effortless. View ranked alternatives, swap with one click, and maintain a full audit trail of every change.
							</p>
							<div class="space-y-3">
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Ranked alternatives</h4>
										<p class="text-[var(--color-text-muted)] text-sm">All candidate parts shown with pricing, stock, and distributor info.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Confirmation dialog</h4>
										<p class="text-[var(--color-text-muted)] text-sm">One-click swap with confirmation to prevent accidental changes.</p>
									</div>
								</div>
								<div class="flex items-start gap-3">
									<span class="text-[var(--color-secondary)] mt-1">✓</span>
									<div>
										<h4 class="text-[var(--color-text)] font-semibold text-sm">Substitution timeline</h4>
										<p class="text-[var(--color-text-muted)] text-sm">Collapsible history showing all swaps with MPN, timestamps, and reason.</p>
									</div>
								</div>
							</div>
						</div>
						<div>
							<!-- Screenshot Placeholder -->
							<div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6 shadow-[var(--shadow-card)]">
								<div class="bg-[var(--color-bg)] rounded border-2 border-dashed border-[var(--color-border)] min-h-[300px] flex flex-col items-center justify-center p-8 text-center">
									<svg class="w-12 h-12 text-[var(--color-text-muted)] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
									</svg>
									<span class="text-[var(--color-text-muted)] text-sm font-mono">SCREENSHOT PLACEHOLDER</span>
									<span class="text-[var(--color-text-muted)] text-xs mt-2">Show alternatives page with ranked candidates and swap confirmation</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Differentiator 6: Admin-Grade Control -->
			<div class="mb-16 bg-[var(--color-surface)] py-16 px-8 rounded-lg shadow-[var(--shadow-card)]">
				<div class="max-w-7xl mx-auto">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
						<div class="order-2 lg:order-2">
							<div class="mb-4 flex items-center gap-3">
