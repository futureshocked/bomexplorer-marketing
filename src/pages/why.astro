							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- CTA -->
			<div class="text-center pt-8 border-t border-[var(--color-border)]">
				<h2 class="text-3xl font-bold text-[var(--color-text)] mb-4 font-mono">Ready to stop manual BOM sourcing?</h2>
				<p class="text-[var(--color-text-muted)] mb-8">Join hardware engineers who've already made the switch.</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
