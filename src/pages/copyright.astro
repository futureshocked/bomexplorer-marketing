<LegalLayout title="Copyright Notice" currentPage="copyright">
<div class="text-[var(--color-text-muted)] text-sm mb-8 text-center"><em>Last updated: April 2026</em></div>

<div class="space-y-8">
  <div class="border-l-4 border-[var(--color-secondary)] pl-6">
    <h2 class="text-xl font-bold text-[var(--color-text)] mb-4 font-mono">1. Copyright Notice</h2>
