---
---

<footer class="bg-[var(--color-surface)] border-t border-transparent bg-gradient-to-r from-transparent via-[var(--color-border)] to-transparent mt-16">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
			<div>
				<a href="/" class="text-2xl font-bold font-mono text-[var(--color-text)] mb-4 block">
					BOM<span class="text-[var(--color-secondary)]">explorer</span>
				</a>
				<p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
					Automate BOM sourcing for KiCad projects. Real-time pricing and stock from Mouser, DigiKey, and OEMSecrets.
				</p>
			</div>
			<div>
				<h3 class="text-[var(--color-text)] font-semibold mb-4 text-sm uppercase tracking-wider">Product</h3>
				<ul class="space-y-2">
					<li><a href="/features" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-sm transition-colors duration-150">Features</a></li>
					<li><a href="/pricing" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-sm transition-colors duration-150">Pricing</a></li>
					<li><a href="/about" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-sm transition-colors duration-150">About</a></li>
				</ul>
			</div>
			<div>
				<h3 class="text-[var(--color-text)] font-semibold mb-4 text-sm uppercase tracking-wider">Support</h3>
				<ul class="space-y-2">
					<li><a href="/faq" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-sm transition-colors duration-150">FAQ</a></li>
					<li><a href="/contact" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-sm transition-colors duration-150">Contact</a></li>
				</ul>
			</div>
		</div>
		<div class="border-t border-[var(--color-border)] pt-8">
			<div class="flex flex-col md:flex-row justify-between items-center mb-4">
				<p class="text-[var(--color-text-muted)] text-xs">
					© 2025 BOMexplorer. All rights reserved.
				</p>
				<div class="flex flex-wrap gap-4 mt-4 md:mt-0">
					<a href="/privacy-policy" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-xs transition-colors duration-150">Privacy Policy</a>
					<a href="/terms-and-conditions" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-xs transition-colors duration-150">Terms & Conditions</a>
					<a href="/disclaimer" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-xs transition-colors duration-150">Disclaimer</a>
					<a href="/refunds-policy" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-xs transition-colors duration-150">Refunds</a>
					<a href="/copyright" class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] text-xs transition-colors duration-150">Copyright</a>
				</div>
			</div>
			<div class="text-center">
				<p class="text-[var(--color-text-muted)] text-xs">
					Built by <a href="https://techexplorations.com" class="text-[var(--color-secondary)] hover:underline transition-colors duration-150">Tech Explorations</a>
				</p>
			</div>
		</div>
	</div>
</footer>