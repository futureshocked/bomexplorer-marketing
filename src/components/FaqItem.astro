---
export interface Props {
	question: string;
	answer: string;
}

const { question, answer } = Astro.props;
---

<details class="block border-b border-[var(--color-border)] group">
	<summary class="list-none cursor-pointer py-4 px-4 -mx-4 focus:outline-none hover:bg-[var(--color-surface-2)] transition-colors duration-150">
		<div class="flex justify-between items-center">
			<h3 class="text-[var(--color-text)] font-medium pr-4 text-base">{question}</h3>
			<svg class="w-5 h-5 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform duration-200 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
			</svg>
		</div>
	</summary>
	<div class="pb-4 px-4 -mx-4 text-[var(--color-text-muted)] text-sm leading-relaxed max-h-96 overflow-hidden transition-all duration-200">
		{answer}
	</div>
</details>