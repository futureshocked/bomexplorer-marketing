---
import MarketingLayout from './MarketingLayout.astro';

interface Props {
  title: string;
  currentPage?: string;
}

const { title, currentPage = "" } = Astro.props;
---

<MarketingLayout title={title} currentPage={currentPage}>
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-[var(--color-text)] mb-4 font-mono">
          {title}
        </h1>
      </div>
      <div class="prose prose-invert max-w-none">
        <slot />
      </div>
    </div>
  </section>
</MarketingLayout>